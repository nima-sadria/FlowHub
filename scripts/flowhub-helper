#!/usr/bin/env bash
# FlowHub privileged helper.
#
# Installed root-owned at /usr/local/lib/flowhub/flowhub-helper. The public
# flowhub wrapper invokes this through a sudoers allowlist. This helper must
# remain conservative: no arbitrary shell execution, no secret printing, and no
# direct use by unprivileged callers.

set -euo pipefail

INSTALL_DIR="${FLOWHUB_INSTALL_DIR:-/opt/FlowHub}"
ENV_FILE="${INSTALL_DIR}/.env.beta"
COMPOSE_FILE="${INSTALL_DIR}/docker-compose.beta.yml"

die() {
    echo "ERROR: $*" >&2
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "flowhub-helper must run as root through the installed flowhub wrapper."
}

ensure_install() {
    [[ -d "$INSTALL_DIR" ]] || die "FlowHub installation directory not found: ${INSTALL_DIR}"
    [[ -f "$COMPOSE_FILE" ]] || die "Docker Compose file not found: ${COMPOSE_FILE}"
    [[ -f "$ENV_FILE" ]] || die "Environment file not found: ${ENV_FILE}"
    cd "$INSTALL_DIR"
}

load_env() {
    set -a
    # shellcheck source=/dev/null
    . "$ENV_FILE"
    set +a
}

compose_cmd() {
    if docker compose version >/dev/null 2>&1; then
        echo "docker compose"
    elif command -v docker-compose >/dev/null 2>&1; then
        echo "docker-compose"
    else
        die "Docker Compose is not available."
    fi
}

run_compose() {
    local dc
    dc="$(compose_cmd)"
    ${dc} --project-directory "$INSTALL_DIR" -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

health_url() {
    load_env
    echo "http://localhost:${BETA_PORT:-8085}/api/health"
}

check_app_health() {
    if command -v curl >/dev/null 2>&1; then
        curl -fsS --max-time 3 "$(health_url)" >/dev/null 2>&1
    else
        run_compose exec -T app curl -fsS --max-time 3 http://localhost:8085/api/health >/dev/null 2>&1
    fi
}

wait_for_app_health() {
    local timeout="${1:-60}"
    local start now
    start="$(date +%s)"
    echo "Waiting for FlowHub to become ready at $(health_url) ..."
    while true; do
        if check_app_health; then
            echo "FlowHub is ready."
            return 0
        fi
        now="$(date +%s)"
        if (( now - start >= timeout )); then
            echo "ERROR: FlowHub did not become ready within ${timeout}s." >&2
            return 1
        fi
        sleep 2
    done
}

public_url() {
    load_env
    local domain="${BETA_DOMAIN:-localhost}"
    local port="${BETA_PORT:-8085}"
    local ssl_mode="${BETA_SSL_MODE:-off}"
    case "$ssl_mode" in
        letsencrypt|manual)
            echo "https://${domain}:${port}/"
            ;;
        self-signed)
            echo "https://${domain}:${port}/"
            ;;
        off|*)
            if [[ "$domain" == "localhost" || "$domain" == "127.0.0.1" ]]; then
                echo "http://localhost:${port}/"
            else
                echo "http://${domain}:${port}/"
            fi
            ;;
    esac
}

install_state() {
    if check_app_health; then
        echo "Running"
    elif [[ -n "$(run_compose ps --status running -q app 2>/dev/null)" ]]; then
        echo "Starting"
    else
        echo "Stopped"
    fi
}

api_state() {
    if check_app_health; then
        echo "Healthy"
    elif [[ -n "$(run_compose ps --status running -q app 2>/dev/null)" ]]; then
        echo "Warning"
    else
        echo "Error"
    fi
}

panel_state() {
    case "$(install_state)" in
        Running) echo "Running" ;;
        Starting) echo "Warning" ;;
        *) echo "Stopped" ;;
    esac
}

database_state() {
    load_env
    if run_compose exec -T postgres pg_isready -U "${BETA_POSTGRES_USER:-flowhub}" -d "${BETA_POSTGRES_DB:-flowhub}" >/dev/null 2>&1; then
        echo "Healthy"
    else
        echo "Unable to verify"
    fi
}

docker_state() {
    if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
        echo "Running"
    elif command -v docker >/dev/null 2>&1; then
        echo "Installed, not reachable"
    else
        echo "Not installed"
    fi
}

version_commit() {
    if [[ -d "${INSTALL_DIR}/.git" ]]; then
        git -C "$INSTALL_DIR" -c safe.directory="$INSTALL_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

run_app_cli() {
    local first="${1:-}"
    case "$first" in
        admin|diagnostics|configure|migrate|integrations)
            if [[ "$first" == "admin" && "${2:-}" =~ ^(reset-password|reset-username|create)$ && " $* " != *" --help "* ]]; then
                run_compose exec app python -m cli.main "$@"
            else
                run_compose exec -T app python -m cli.main "$@"
            fi
            ;;
        *)
            die "Unsupported app CLI command: ${first:-<empty>}"
            ;;
    esac
}

run_installer() {
    local mode="${1:-}"
    case "$mode" in
        install) bash "${INSTALL_DIR}/installer/install.sh" ;;
        upgrade) bash "${INSTALL_DIR}/installer/install.sh" --upgrade ;;
        repair) bash "${INSTALL_DIR}/installer/install.sh" --repair ;;
        reinstall) bash "${INSTALL_DIR}/installer/install.sh" --reinstall ;;
        uninstall) bash "${INSTALL_DIR}/installer/install.sh" --uninstall ;;
        *) die "Unsupported installer action: ${mode:-<empty>}" ;;
    esac
}

create_backup() {
    mkdir -p "${INSTALL_DIR}/backups"
    chmod 750 "${INSTALL_DIR}/backups" 2>/dev/null || true
    local stamp archive
    stamp="$(date -u +%Y%m%dT%H%M%SZ)"
    archive="${INSTALL_DIR}/backups/flowhub-${stamp}.tar.gz"
    tar --exclude='logs/admin-credentials.txt' -C "$INSTALL_DIR" -czf "$archive" .env.beta storage logs 2>/dev/null \
        || tar -C "$INSTALL_DIR" -czf "$archive" .env.beta storage
    chmod 600 "$archive"
    echo "Backup created: ${archive}"
}

restore_backup() {
    local archive="${1:-}"
    [[ -n "$archive" && -f "$archive" ]] || die "restore requires a backup archive path."
    tar -xzf "$archive" -C "$INSTALL_DIR"
    echo "Backup restored. Run: flowhub repair"
}

validate_domain() {
    local domain="${1:-}"
    [[ -n "$domain" ]] || die "Domain is required."
    [[ "$domain" != http://* && "$domain" != https://* ]] || die "Enter only the host, for example: kharidbezan.com"
    [[ "$domain" != *"/"* && "$domain" != *":"* && "$domain" != *" "* ]] || die "Domain must be a hostname without scheme, port, path, or spaces."
    [[ "$domain" =~ ^([A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?\.)*[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$ ]] \
        || die "Invalid domain host: ${domain}"
}

validate_port() {
    local port="${1:-}"
    [[ "$port" =~ ^[0-9]+$ ]] || die "Port must be a number."
    (( port >= 1 && port <= 65535 )) || die "Port must be between 1 and 65535."
}

validate_ip() {
    local ip="${1:-}"
    [[ -n "$ip" ]] || die "IP address is required."
    [[ "$ip" != *" "* && "$ip" != *":"* && "$ip" != *"/"* ]] || die "IP address must not contain spaces, ports, or paths."
    if [[ "$ip" == "localhost" ]]; then
        return 0
    fi
    if [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
        local IFS=.
        local -a parts
        read -r -a parts <<< "$ip"
        for part in "${parts[@]}"; do
            (( part >= 0 && part <= 255 )) || die "Invalid IPv4 address: ${ip}"
        done
        return 0
    fi
    die "Invalid IP address: ${ip}"
}

validate_ssl_mode() {
    case "${1:-}" in
        off|self-signed|letsencrypt|manual) ;;
        *) die "TLS mode must be one of: off, self-signed, letsencrypt, manual." ;;
    esac
}

set_env_field() {
    local key="${1:-}" value="${2:-}"
    [[ -n "$key" ]] || die "Environment key is required."
    [[ -f "$ENV_FILE" ]] || die "Environment file not found: ${ENV_FILE}"

    local tmp
    tmp="$(mktemp)"
    if grep -qE "^${key}=" "$ENV_FILE"; then
        awk -v key="$key" -v value="$value" 'BEGIN { done=0 } $0 ~ "^" key "=" { print key "=" value; done=1; next } { print } END { if (!done) print key "=" value }' "$ENV_FILE" > "$tmp"
    else
        cat "$ENV_FILE" > "$tmp"
        printf '%s=%s\n' "$key" "$value" >> "$tmp"
    fi
    install -o root -g root -m 0600 "$tmp" "$ENV_FILE"
    rm -f "$tmp"
}

set_domain() {
    local domain="${1:-}"
    validate_domain "$domain"
    set_env_field "BETA_DOMAIN" "$domain"
    echo "Domain updated: ${domain}"
    echo "Run: flowhub start"
}

set_port() {
    local port="${1:-}"
    validate_port "$port"
    set_env_field "BETA_PORT" "$port"
    echo "Port updated: ${port}"
    echo "Run: flowhub start"
}

set_domain_ssl() {
    local domain="${1:-}" port="${2:-}"
    validate_domain "$domain"
    validate_port "$port"
    set_env_field "BETA_DOMAIN" "$domain"
    set_env_field "BETA_PORT" "$port"
    set_env_field "BETA_SSL_MODE" "letsencrypt"
    set_env_field "BETA_BIND_IP" "0.0.0.0"
    echo "Base URL: https://${domain}:${port}/"
    echo "TLS mode: letsencrypt"
    echo "Run: flowhub start"
}

set_ip_port() {
    local ip="${1:-}" port="${2:-}"
    validate_ip "$ip"
    validate_port "$port"
    set_env_field "BETA_BIND_IP" "$ip"
    set_env_field "BETA_DOMAIN" "$ip"
    set_env_field "BETA_PORT" "$port"
    set_env_field "BETA_SSL_MODE" "off"
    echo "Base URL: http://${ip}:${port}/"
    echo "TLS mode: off"
    echo "Run: flowhub start"
}

status_overview() {
    echo "Database: $(database_state)"
    echo "Panel: $(panel_state)"
    echo "API: $(api_state)"
}

recent_logs() {
    run_compose logs --tail="${1:-120}" app
}

recent_errors() {
    local output
    output="$(run_compose logs --tail="${1:-240}" app 2>&1 | grep -Ei 'error|warning|warn|failed|exception|traceback' || true)"
    if [[ -n "$output" ]]; then
        printf '%s\n' "$output"
    else
        echo "No recent errors or warnings found."
    fi
}

tls_status() {
    load_env
    echo "TLS mode: ${BETA_SSL_MODE:-off}"
    echo "Domain: ${BETA_DOMAIN:-localhost}"
    echo "Public URL: $(public_url)"
    case "${BETA_SSL_MODE:-off}" in
        letsencrypt)
            echo "Let's Encrypt mode is configured for external reverse-proxy termination."
            echo "Certificate issuance is handled by the reverse proxy; FlowHub does not store certificate private keys."
            ;;
        manual)
            echo "Manual TLS mode is configured for external reverse-proxy termination."
            ;;
        self-signed)
            echo "Self-signed TLS mode is configured."
            ;;
        off|*)
            echo "TLS mode is off. Use 'flowhub tls letsencrypt <domain>' after DNS points to this host and a reverse proxy is ready."
            ;;
    esac
}

tls_letsencrypt() {
    local domain="${1:-}"
    validate_domain "$domain"
    set_env_field "BETA_DOMAIN" "$domain"
    set_env_field "BETA_SSL_MODE" "letsencrypt"
    echo "Let's Encrypt mode configured for: ${domain}"
    echo "Public URL: https://${domain}"
    echo "Configure your external reverse proxy to request and renew the certificate for ${domain}."
    echo "Run: flowhub start"
}

tls_set_mode() {
    local mode="${1:-}"
    validate_ssl_mode "$mode"
    set_env_field "BETA_SSL_MODE" "$mode"
    echo "TLS mode updated: ${mode}"
    echo "Run: flowhub start"
}

require_root
cmd="${1:-}"
shift || true

case "$cmd" in
    state)
        ensure_install
        case "${1:-}" in
            app) install_state ;;
            database) database_state ;;
            api) api_state ;;
            panel) panel_state ;;
            safety) echo "Read-only" ;;
            public-url) public_url ;;
            docker) docker_state ;;
            version) version_commit ;;
            *) die "Unsupported state field: ${1:-<empty>}" ;;
        esac
        ;;
    status)
        ensure_install
        run_compose ps "$@"
        ;;
    health)
        ensure_install
        curl -fsS "$(health_url)"
        echo
        ;;
    start)
        ensure_install
        run_compose up -d "$@"
        wait_for_app_health 60
        ;;
    restart)
        ensure_install
        run_compose restart "$@"
        wait_for_app_health 60
        ;;
    stop)
        ensure_install
        run_compose stop "$@"
        ;;
    logs)
        ensure_install
        service="${1:-app}"
        case "$service" in
            app|postgres) run_compose logs -f "$service" ;;
            recent) recent_logs "${2:-120}" ;;
            errors) recent_errors "${2:-240}" ;;
            *) die "Unsupported log service: ${service}" ;;
        esac
        ;;
    backup)
        ensure_install
        create_backup
        ;;
    restore)
        ensure_install
        restore_backup "$@"
        ;;
    config)
        ensure_install
        case "${1:-}" in
            set-domain) set_domain "${2:-}" ;;
            set-port) set_port "${2:-}" ;;
            set-domain-ssl) set_domain_ssl "${2:-}" "${3:-}" ;;
            set-ip-port) set_ip_port "${2:-}" "${3:-}" ;;
            *) die "Unsupported config command: ${1:-<empty>}" ;;
        esac
        ;;
    base-url)
        ensure_install
        public_url
        ;;
    overview)
        ensure_install
        status_overview
        ;;
    tls)
        ensure_install
        case "${1:-}" in
            status) tls_status ;;
            letsencrypt) tls_letsencrypt "${2:-}" ;;
            mode) tls_set_mode "${2:-}" ;;
            off) tls_set_mode off ;;
            *) die "Unsupported TLS command: ${1:-<empty>}" ;;
        esac
        ;;
    app-cli)
        ensure_install
        run_app_cli "$@"
        ;;
    installer)
        ensure_install
        run_installer "$@"
        ;;
    *)
        die "Unsupported helper command: ${cmd:-<empty>}"
        ;;
esac
