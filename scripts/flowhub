#!/usr/bin/env bash
# FlowHub operator CLI wrapper.
#
# This script is intentionally unprivileged. It never reads .env.beta directly.
# Privileged Docker/config operations go through the root-owned helper installed
# by installer/install.sh with a strict sudoers allowlist.

set -euo pipefail

INSTALL_DIR="${FLOWHUB_INSTALL_DIR:-/opt/FlowHub}"
LEGACY_INSTALL_DIR="/opt/flowhub" # Legacy Compatibility
HELPER="${FLOWHUB_HELPER:-/usr/local/lib/flowhub/flowhub-helper}"
SELF_PATH="${BASH_SOURCE[0]}"

usage() {
    cat <<'EOF'
FlowHub management commands:

  flowhub                  Open the interactive management menu
  flowhub help             Show this help
  flowhub install          Run first-time installation when FlowHub is not installed
  flowhub upgrade          Pull latest code, rebuild, migrate, restart
  flowhub update           Alias for upgrade
  flowhub repair           Re-run migrations and health checks
  flowhub status           Show Docker service status
  flowhub health           Check the running application health endpoint
  flowhub logs [service]   Follow service logs
  flowhub start            Start the Docker stack
  flowhub restart          Restart services and wait for readiness
  flowhub stop             Stop services
  flowhub uninstall        Run the uninstaller
  flowhub backup           Create a local backup archive
  flowhub restore FILE     Restore a local backup archive
  flowhub base-url         Show the configured panel URL
  flowhub overview         Show concise database, panel, and API status
  flowhub errors           Show recent errors and warnings
  flowhub domain set HOST  Set the public domain host
  flowhub tls status       Show TLS / Let's Encrypt configuration status
  flowhub tls letsencrypt HOST
                          Configure Let's Encrypt mode for an external proxy
  flowhub admin list       List administrator accounts
  flowhub admin create     Create an emergency administrator account
  flowhub admin delete     Delete an administrator account safely
  flowhub admin reset-username
                          Rename an administrator account and revoke sessions
  flowhub admin reset-password
                          Reset an administrator password interactively

App CLI commands are executed inside the app container, for example:
  flowhub diagnostics run
EOF
}

helper() {
    if [[ ! -x "$HELPER" ]]; then
        echo "ERROR: FlowHub helper is not installed: ${HELPER}" >&2
        echo "Run the installer repair command from ${INSTALL_DIR}." >&2
        exit 1
    fi

    if [[ "${EUID}" -eq 0 ]]; then
        "$HELPER" "$@"
        return
    fi

    if ! command -v sudo >/dev/null 2>&1; then
        echo "ERROR: sudo is required for FlowHub operator commands." >&2
        exit 1
    fi

    sudo -n "$HELPER" "$@"
}

repair_with_fallback() {
    if helper installer repair; then
        return 0
    fi

    if [[ -t 0 && -f "${INSTALL_DIR}/installer/install.sh" ]]; then
        echo "FlowHub helper access is not configured yet. Running one-time repair with sudo authentication." >&2
        sudo bash "${INSTALL_DIR}/installer/install.sh" --repair
        return $?
    fi

    echo "ERROR: FlowHub helper access is not configured. Run: sudo ${INSTALL_DIR}/installer/install.sh --repair" >&2
    return 1
}

fail_missing_install() {
    echo "ERROR: FlowHub installation directory not found: ${INSTALL_DIR}" >&2
    if [[ -d "$LEGACY_INSTALL_DIR" ]]; then
        echo "Legacy Compatibility: installation detected at ${LEGACY_INSTALL_DIR}." >&2
        echo "Run the installer to migrate it to ${INSTALL_DIR}." >&2
    fi
    exit 1
}

ensure_install_path() {
    [[ -d "$INSTALL_DIR" ]] || fail_missing_install
}

is_installed() {
    [[ -d "$INSTALL_DIR" ]]
}

already_installed_message() {
    echo "FlowHub is already installed. Use Update instead." >&2
}

run_first_install() {
    if is_installed; then
        already_installed_message
        exit 1
    fi

    if [[ -f "${INSTALL_DIR}/installer/install.sh" ]]; then
        bash "${INSTALL_DIR}/installer/install.sh"
    elif [[ -f "./installer/install.sh" ]]; then
        bash "./installer/install.sh"
    else
        cat >&2 <<EOF
FlowHub is not installed at ${INSTALL_DIR}.
Install with:
  curl -fsSL https://raw.githubusercontent.com/nima-sadria/FlowHub/main/installer/install.sh | sudo bash
EOF
        exit 1
    fi
}

menu_run() {
    local label="$1"
    shift
    local status
    echo ""
    echo "== ${label} =="
    set +e
    "$@"
    status=$?
    set -e
    if [[ "$status" -ne 0 ]]; then
        echo "Command exited with status ${status}."
    fi
    return 0
}

footer_value() {
    if [[ ! -x "$HELPER" ]]; then
        echo "Unable to verify"
        return 0
    fi
    helper "$@" 2>/dev/null || echo "Unable to verify"
}

cli_self_check() {
    local repo_wrapper="${INSTALL_DIR}/scripts/flowhub"
    if [[ -f "$repo_wrapper" && -f "$SELF_PATH" ]] && ! cmp -s "$repo_wrapper" "$SELF_PATH" 2>/dev/null; then
        echo "CLI wrapper: update available. Run: flowhub repair"
    fi
}

show_management_menu() {
    local choice confirm domain ip port
    while true; do
        clear 2>/dev/null || true
        cat <<'EOF'
FlowHub Management

Maintenance
1. Install
2. Update
3. Uninstall
4. Domain + SSL Setup
5. IP + Port Setup

Account
6. Admin Setup
7. Show Base URL
8. Show Admin Users
9. Add Admin User
10. Delete Admin User

Status
11. Status Overview

Diagnostics
12. Logs
13. Errors & Warnings

0. Exit
EOF
        echo ""
        cli_self_check
        echo ""
        read -r -p "Please enter your selection [0-13]: " choice || return 0
        choice="${choice//$'\r'/}"
        case "$choice" in
            0|"q"|"quit"|"exit") echo "Exiting."; return 0 ;;
            1)
                if is_installed; then
                    echo "FlowHub is already installed. Use Update instead."
                else
                    menu_run "Install" "$0" install
                fi
                ;;
            2) menu_run "Update" "$0" update ;;
            3)
                read -r -p "Uninstall FlowHub? This requires confirmation in the uninstaller too. Type UNINSTALL to continue: " confirm
                if [[ "$confirm" == "UNINSTALL" ]]; then
                    menu_run "Uninstall" "$0" uninstall
                else
                    echo "Uninstall cancelled."
                fi
                ;;
            4)
                read -r -p "Domain host: " domain
                read -r -p "Public panel port: " port
                menu_run "Domain + SSL Setup" helper config set-domain-ssl "$domain" "$port"
                ;;
            5)
                read -r -p "Listen IP: " ip
                read -r -p "Panel port: " port
                menu_run "IP + Port Setup" helper config set-ip-port "$ip" "$port"
                ;;
            6) menu_run "Admin Setup" "$0" admin create ;;
            7) menu_run "Base URL" helper base-url ;;
            8) menu_run "Admin Users" "$0" admin list ;;
            9) menu_run "Add Admin User" "$0" admin create ;;
            10) menu_run "Delete Admin User" "$0" admin delete ;;
            11) menu_run "Status Overview" helper overview ;;
            12) menu_run "Logs" helper logs recent ;;
            13) menu_run "Errors & Warnings" helper logs errors ;;
            *) echo "Invalid selection: ${choice}" ;;
        esac
        echo ""
        read -r -p "Press Enter to return to the menu..." _ || return 0
    done
}

cmd="${1:-menu}"
case "$cmd" in
    menu)
        show_management_menu
        ;;
    ""|-h|--help|help)
        usage
        ;;
    install)
        run_first_install
        ;;
    upgrade|update)
        ensure_install_path
        helper installer upgrade
        ;;
    repair)
        ensure_install_path
        repair_with_fallback
        ;;
    reinstall)
        ensure_install_path
        helper installer reinstall
        ;;
    uninstall)
        ensure_install_path
        helper installer uninstall
        ;;
    status|health|start|restart|stop|backup)
        ensure_install_path
        helper "$@"
        ;;
    overview)
        ensure_install_path
        helper overview
        ;;
    base-url)
        ensure_install_path
        helper base-url
        ;;
    errors)
        ensure_install_path
        helper logs errors
        ;;
    logs)
        ensure_install_path
        shift
        helper logs "$@"
        ;;
    restore)
        ensure_install_path
        shift
        helper restore "$@"
        ;;
    domain)
        ensure_install_path
        shift
        case "${1:-}" in
            set)
                shift
                helper config set-domain "${1:-}"
                ;;
            *)
                echo "Usage: flowhub domain set HOST" >&2
                exit 1
                ;;
        esac
        ;;
    tls)
        ensure_install_path
        shift
        helper tls "$@"
        ;;
    admin|diagnostics|configure|migrate|integrations)
        ensure_install_path
        helper app-cli "$@"
        ;;
    *)
        ensure_install_path
        helper app-cli "$@"
        ;;
esac
