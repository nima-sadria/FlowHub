#!/usr/bin/env bash
# FlowHub operator CLI wrapper.
#
# This script is intentionally unprivileged. It never reads .env.beta directly.
# Privileged Docker/config operations go through the root-owned helper installed
# by installer/install.sh with a strict sudoers allowlist.

set -euo pipefail

INSTALL_DIR="${FLOWHUB_INSTALL_DIR:-/opt/FlowHub}"
LEGACY_INSTALL_DIR="/opt/flowhub" # Legacy Compatibility
HELPER="${FLOWHUB_HELPER:-/usr/local/lib/flowhub/flowhub-helper}"
SELF_PATH="${BASH_SOURCE[0]}"

usage() {
    cat <<'EOF'
FlowHub management commands:

  flowhub                  Open the interactive management menu
  flowhub help             Show this help
  flowhub install          Run first-time installation when FlowHub is not installed
  flowhub upgrade          Pull latest code, rebuild, migrate, restart
  flowhub update           Alias for upgrade
  flowhub repair           Re-run migrations and health checks
  flowhub status           Show Docker service status
  flowhub health           Check the running application health endpoint
  flowhub logs [service]   Follow service logs
  flowhub start            Start the Docker stack
  flowhub restart          Restart services and wait for readiness
  flowhub stop             Stop services
  flowhub uninstall        Run the uninstaller
  flowhub backup           Create a local backup archive
  flowhub restore FILE     Restore a local backup archive
  flowhub domain set HOST  Set the public domain host
  flowhub tls status       Show TLS / Let's Encrypt configuration status
  flowhub tls letsencrypt HOST
                          Configure Let's Encrypt mode for an external proxy
  flowhub admin list       List administrator accounts
  flowhub admin create     Create an emergency administrator account
  flowhub admin reset-username
                          Rename an administrator account and revoke sessions
  flowhub admin reset-password
                          Reset an administrator password interactively

App CLI commands are executed inside the app container, for example:
  flowhub diagnostics run
EOF
}

helper() {
    if [[ ! -x "$HELPER" ]]; then
        echo "ERROR: FlowHub helper is not installed: ${HELPER}" >&2
        echo "Run the installer repair command from ${INSTALL_DIR}." >&2
        exit 1
    fi

    if [[ "${EUID}" -eq 0 ]]; then
        "$HELPER" "$@"
        return
    fi

    if ! command -v sudo >/dev/null 2>&1; then
        echo "ERROR: sudo is required for FlowHub operator commands." >&2
        exit 1
    fi

    sudo -n "$HELPER" "$@"
}

repair_with_fallback() {
    if helper installer repair; then
        return 0
    fi

    if [[ -t 0 && -f "${INSTALL_DIR}/installer/install.sh" ]]; then
        echo "FlowHub helper access is not configured yet. Running one-time repair with sudo authentication." >&2
        sudo bash "${INSTALL_DIR}/installer/install.sh" --repair
        return $?
    fi

    echo "ERROR: FlowHub helper access is not configured. Run: sudo ${INSTALL_DIR}/installer/install.sh --repair" >&2
    return 1
}

fail_missing_install() {
    echo "ERROR: FlowHub installation directory not found: ${INSTALL_DIR}" >&2
    if [[ -d "$LEGACY_INSTALL_DIR" ]]; then
        echo "Legacy Compatibility: installation detected at ${LEGACY_INSTALL_DIR}." >&2
        echo "Run the installer to migrate it to ${INSTALL_DIR}." >&2
    fi
    exit 1
}

ensure_install_path() {
    [[ -d "$INSTALL_DIR" ]] || fail_missing_install
}

is_installed() {
    [[ -d "$INSTALL_DIR" ]]
}

already_installed_message() {
    echo "FlowHub is already installed at ${INSTALL_DIR}. Use flowhub upgrade, flowhub repair, or flowhub reinstall." >&2
}

run_first_install() {
    if is_installed; then
        already_installed_message
        exit 1
    fi

    if [[ -f "${INSTALL_DIR}/installer/install.sh" ]]; then
        bash "${INSTALL_DIR}/installer/install.sh"
    elif [[ -f "./installer/install.sh" ]]; then
        bash "./installer/install.sh"
    else
        cat >&2 <<EOF
FlowHub is not installed at ${INSTALL_DIR}.
Install with:
  curl -fsSL https://raw.githubusercontent.com/nima-sadria/FlowHub/main/installer/install.sh | sudo bash
EOF
        exit 1
    fi
}

menu_run() {
    local label="$1"
    shift
    local status
    echo ""
    echo "== ${label} =="
    set +e
    "$@"
    status=$?
    set -e
    if [[ "$status" -ne 0 ]]; then
        echo "Command exited with status ${status}."
    fi
    return 0
}

footer_value() {
    if [[ ! -x "$HELPER" ]]; then
        echo "Unable to verify"
        return 0
    fi
    helper "$@" 2>/dev/null || echo "Unable to verify"
}

cli_self_check() {
    local repo_wrapper="${INSTALL_DIR}/scripts/flowhub"
    if [[ -f "$repo_wrapper" && -f "$SELF_PATH" ]] && ! cmp -s "$repo_wrapper" "$SELF_PATH" 2>/dev/null; then
        echo "CLI wrapper: update available. Run: flowhub repair"
    fi
}

print_menu_footer() {
    echo ""
    echo "Panel state: $(footer_value state app)"
    echo "Database: $(footer_value state database)"
    echo "Safety mode: $(footer_value state safety)"
    echo "Install path: ${INSTALL_DIR}"
    echo "Public URL: $(footer_value state public-url)"
    echo "Docker: $(footer_value state docker)"
    echo "Version / commit: $(footer_value state version)"
    cli_self_check
}

show_management_menu() {
    local choice archive new_domain new_port
    while true; do
        clear 2>/dev/null || true
        if ! is_installed; then
            cat <<'EOF'
FlowHub Management

0. Exit

Install / Setup
1. Install FlowHub
EOF
            echo ""
            echo "Panel state: Not installed"
            echo "Install path: ${INSTALL_DIR}"
            echo ""
            read -r -p "Please enter your selection [0-1]: " choice || return 0
            choice="${choice//$'\r'/}"
            case "$choice" in
                0|"q"|"quit"|"exit") echo "Exiting."; return 0 ;;
                1) menu_run "Install FlowHub" "$0" install ;;
                *) echo "Invalid selection: ${choice}" ;;
            esac
            echo ""
            read -r -p "Press Enter to return to the menu..." _ || return 0
            continue
        fi

        cat <<'EOF'
FlowHub Management

0. Exit

Maintenance
1. Upgrade
2. Repair
3. Reinstall
4. Uninstall

Account
5. Reset Administrator Username
6. Reset Administrator Password
7. View Current Admins

System
8. Status
9. Health
10. Diagnostics
11. Logs

Services
12. Start
13. Stop
14. Restart
15. Backup
16. Restore

Configuration
17. View Current Settings
18. Edit Domain / Public URL
19. Manage TLS / Let's Encrypt
20. Change Port
21. Show Install Path

Security
22. Rotate Secrets
23. Check Secret Exposure
24. View Safety Status

Advanced
25. Docker Compose Status
26. Database Status
27. Migration Status
28. Shell into App Container
EOF
        print_menu_footer
        echo ""
        read -r -p "Please enter your selection [0-28]: " choice || return 0
        choice="${choice//$'\r'/}"
        case "$choice" in
            0|"q"|"quit"|"exit") echo "Exiting."; return 0 ;;
            1) menu_run "Upgrade" "$0" upgrade ;;
            2) menu_run "Repair" "$0" repair ;;
            3) menu_run "Reinstall" "$0" reinstall ;;
            4) menu_run "Uninstall" "$0" uninstall ;;
            5) menu_run "Reset Administrator Username" "$0" admin reset-username ;;
            6) menu_run "Reset Administrator Password" "$0" admin reset-password ;;
            7) menu_run "Current Administrators" "$0" admin list ;;
            8) menu_run "Status" "$0" status ;;
            9) menu_run "Health" "$0" health ;;
            10) menu_run "Diagnostics" "$0" diagnostics run ;;
            11) menu_run "Logs" "$0" logs ;;
            12) menu_run "Start" "$0" start ;;
            13) menu_run "Stop" "$0" stop ;;
            14) menu_run "Restart" "$0" restart ;;
            15) menu_run "Backup" "$0" backup ;;
            16)
                read -r -p "Backup archive path: " archive
                menu_run "Restore" "$0" restore "$archive"
                ;;
            17) menu_run "Current Settings" "$0" configure show ;;
            18)
                read -r -p "New domain / public URL host: " new_domain
                menu_run "Edit Domain / Public URL" helper config set-domain "$new_domain"
                ;;
            19)
                show_tls_menu
                ;;
            20)
                read -r -p "New port: " new_port
                menu_run "Change Port" helper config set-port "$new_port"
                ;;
            21) echo "Install path: ${INSTALL_DIR}" ;;
            22) echo "Secret rotation is not automated in this release. Rotate values in .env.beta, then run: flowhub repair" ;;
            23) menu_run "Check Secret Exposure" "$0" configure verify ;;
            24) echo "Safety mode: Read-only. Apply, Scheduler, WooCommerce writes, and spreadsheet writes are disabled." ;;
            25) menu_run "Docker Compose Status" "$0" status ;;
            26) echo "Database: $(footer_value state database)" ;;
            27) menu_run "Migration Status" "$0" migrate status ;;
            28) menu_run "App Container Shell" helper shell ;;
            *) echo "Invalid selection: ${choice}" ;;
        esac
        echo ""
        read -r -p "Press Enter to return to the menu..." _ || return 0
    done
}

show_tls_menu() {
    local tls_choice tls_domain tls_mode
    cat <<'EOF'

TLS / Let's Encrypt
0. Back
1. Show TLS Status
2. Configure Let's Encrypt Mode
3. Set TLS Mode
4. Disable TLS
EOF
    read -r -p "Please enter your selection [0-4]: " tls_choice || return 0
    tls_choice="${tls_choice//$'\r'/}"
    case "$tls_choice" in
        0|"q"|"quit"|"back") return 0 ;;
        1) menu_run "TLS Status" helper tls status ;;
        2)
            read -r -p "Domain host for Let's Encrypt: " tls_domain
            menu_run "Configure Let's Encrypt Mode" helper tls letsencrypt "$tls_domain"
            ;;
        3)
            read -r -p "TLS mode [off/self-signed/letsencrypt/manual]: " tls_mode
            menu_run "Set TLS Mode" helper tls mode "$tls_mode"
            ;;
        4) menu_run "Disable TLS" helper tls off ;;
        *) echo "Invalid selection: ${tls_choice}" ;;
    esac
}

cmd="${1:-menu}"
case "$cmd" in
    menu)
        show_management_menu
        ;;
    ""|-h|--help|help)
        usage
        ;;
    install)
        run_first_install
        ;;
    upgrade|update)
        ensure_install_path
        helper installer upgrade
        ;;
    repair)
        ensure_install_path
        repair_with_fallback
        ;;
    reinstall)
        ensure_install_path
        helper installer reinstall
        ;;
    uninstall)
        ensure_install_path
        helper installer uninstall
        ;;
    status|health|start|restart|stop|backup)
        ensure_install_path
        helper "$@"
        ;;
    logs)
        ensure_install_path
        shift
        helper logs "$@"
        ;;
    restore)
        ensure_install_path
        shift
        helper restore "$@"
        ;;
    domain)
        ensure_install_path
        shift
        case "${1:-}" in
            set)
                shift
                helper config set-domain "${1:-}"
                ;;
            *)
                echo "Usage: flowhub domain set HOST" >&2
                exit 1
                ;;
        esac
        ;;
    tls)
        ensure_install_path
        shift
        helper tls "$@"
        ;;
    admin|diagnostics|configure|migrate|integrations)
        ensure_install_path
        helper app-cli "$@"
        ;;
    *)
        ensure_install_path
        helper app-cli "$@"
        ;;
esac
