#!/usr/bin/env bash
# FlowHub management CLI wrapper.
#
# Installed to /usr/local/bin/flowhub by installer/install.sh.

set -euo pipefail

INSTALL_DIR="${FLOWHUB_INSTALL_DIR:-/opt/FlowHub}"
LEGACY_INSTALL_DIR="/opt/flowhub" # Legacy Compatibility
ENV_FILE="${INSTALL_DIR}/.env.beta"
COMPOSE_FILE="${INSTALL_DIR}/docker-compose.beta.yml"

usage() {
    cat <<'EOF'
FlowHub management commands:

  flowhub                  Open the interactive management menu
  flowhub help             Show this help
  flowhub install          Run the installer
  flowhub upgrade          Pull latest code, rebuild, migrate, restart
  flowhub update           Alias for upgrade
  flowhub repair           Re-run migrations and health checks
  flowhub status           Show Docker service status
  flowhub health           Check the running application health endpoint
  flowhub logs [service]   Follow service logs
  flowhub start            Start the Docker stack
  flowhub restart          Restart services
  flowhub stop             Stop services
  flowhub uninstall        Run the uninstaller
  flowhub backup           Create a local backup archive
  flowhub restore FILE     Restore a local backup archive
  flowhub admin list       List administrator accounts
  flowhub admin create     Create an emergency administrator account
  flowhub admin reset-username
                          Rename an administrator account and revoke sessions
  flowhub admin reset-password
                          Reset an administrator password and revoke sessions

App CLI commands are executed inside the app container, for example:
  flowhub diagnostics run
EOF
}

fail_missing_install() {
    echo "ERROR: FlowHub installation directory not found: ${INSTALL_DIR}" >&2
    if [[ -d "$LEGACY_INSTALL_DIR" ]]; then
        echo "Legacy Compatibility: installation detected at ${LEGACY_INSTALL_DIR}." >&2
        echo "Run the installer to migrate it to ${INSTALL_DIR}." >&2
    fi
    exit 1
}

ensure_install() {
    [[ -d "$INSTALL_DIR" ]] || fail_missing_install
    [[ -f "$COMPOSE_FILE" ]] || {
        echo "ERROR: Docker Compose file not found: ${COMPOSE_FILE}" >&2
        exit 1
    }
    [[ -f "$ENV_FILE" ]] || {
        echo "ERROR: Environment file not found: ${ENV_FILE}" >&2
        exit 1
    }
    cd "$INSTALL_DIR"
    set -a
    # shellcheck source=/dev/null
    . "$ENV_FILE"
    set +a
}

compose_cmd() {
    if docker compose version >/dev/null 2>&1; then
        echo "docker compose"
    elif command -v docker-compose >/dev/null 2>&1; then
        echo "docker-compose"
    else
        echo "ERROR: Docker Compose is not available." >&2
        exit 1
    fi
}

run_compose() {
    local dc
    dc="$(compose_cmd)"
    ${dc} --project-directory "$INSTALL_DIR" -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

run_app_cli() {
    run_compose exec -T app python -m cli.main "$@"
}

health_url() {
    echo "http://localhost:${BETA_PORT:-8085}/api/health"
}

check_app_health() {
    if command -v curl >/dev/null 2>&1; then
        curl -fsS --max-time 3 "$(health_url)" >/dev/null 2>&1
    else
        run_compose exec -T app curl -fsS --max-time 3 http://localhost:8085/api/health >/dev/null 2>&1
    fi
}

wait_for_app_health() {
    local timeout="${1:-60}"
    local start now
    start="$(date +%s)"
    echo "Waiting for FlowHub to become ready at $(health_url) ..."
    while true; do
        if check_app_health; then
            echo "FlowHub is ready."
            return 0
        fi
        now="$(date +%s)"
        if (( now - start >= timeout )); then
            echo "WARNING: FlowHub did not become ready within ${timeout}s." >&2
            echo "Services may still be starting. Check with: flowhub health" >&2
            return 1
        fi
        sleep 2
    done
}

load_env_if_present() {
    if [[ -f "$ENV_FILE" ]]; then
        set -a
        # shellcheck source=/dev/null
        . "$ENV_FILE"
        set +a
    fi
}

public_url() {
    load_env_if_present
    local domain="${BETA_DOMAIN:-localhost}"
    local port="${BETA_PORT:-8085}"
    if [[ "$domain" == "localhost" || "$domain" == "127.0.0.1" ]]; then
        echo "http://localhost:${port}"
    else
        echo "http://${domain}:${port}"
    fi
}

install_state() {
    if [[ ! -d "$INSTALL_DIR" ]]; then
        echo "Not installed"
    elif [[ -f "$COMPOSE_FILE" && -f "$ENV_FILE" ]]; then
        if check_app_health; then
            echo "Running"
        elif run_compose ps --status running -q app >/dev/null 2>&1 && [[ -n "$(run_compose ps --status running -q app 2>/dev/null)" ]]; then
            echo "Starting"
        else
            echo "Stopped"
        fi
    else
        echo "Incomplete"
    fi
}

database_state() {
    if [[ ! -f "$COMPOSE_FILE" || ! -f "$ENV_FILE" ]]; then
        echo "Unknown"
        return
    fi
    load_env_if_present
    if run_compose exec -T postgres pg_isready -U "${BETA_POSTGRES_USER:-flowhub}" -d "${BETA_POSTGRES_DB:-flowhub}" >/dev/null 2>&1; then
        echo "Healthy"
    else
        echo "Unable to verify"
    fi
}

docker_state() {
    if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
        echo "Running"
    elif command -v docker >/dev/null 2>&1; then
        echo "Installed, not reachable"
    else
        echo "Not installed"
    fi
}

version_commit() {
    if [[ -d "${INSTALL_DIR}/.git" ]]; then
        git -C "$INSTALL_DIR" rev-parse --short HEAD 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

print_menu_footer() {
    echo ""
    echo "Panel state: $(install_state)"
    echo "Database: $(database_state)"
    echo "Safety mode: Read-only"
    echo "Install path: ${INSTALL_DIR}"
    echo "Public URL: $(public_url)"
    echo "Docker: $(docker_state)"
    echo "Version / commit: $(version_commit)"
}

menu_run() {
    local label="$1"
    shift
    local status
    echo ""
    echo "== ${label} =="
    set +e
    "$@"
    status=$?
    set -e
    if [[ "$status" -ne 0 ]]; then
        echo "Command exited with status ${status}."
    fi
    return 0
}

show_management_menu() {
    local choice
    while true; do
        clear 2>/dev/null || true
        cat <<'EOF'
FlowHub Management

0. Exit

Install / Update
1. Install
2. Upgrade
3. Repair
4. Reinstall
5. Uninstall

Account
6. Reset Administrator Username
7. Reset Administrator Password
8. View Current Admins

System
9. Status
10. Health
11. Diagnostics
12. Logs

Services
13. Start
14. Stop
15. Restart
16. Backup
17. Restore

Configuration
18. View Current Settings
19. Edit Domain / Public URL
20. Change Port
21. Show Install Path

Security
22. Rotate Secrets
23. Check Secret Exposure
24. View Safety Status

Advanced
25. Docker Compose Status
26. Database Status
27. Migration Status
28. Shell into App Container
EOF
        print_menu_footer
        echo ""
        read -r -p "Please enter your selection [0-28]: " choice || return 0
        choice="${choice//$'\r'/}"
        case "$choice" in
            0|"q"|"quit"|"exit") echo "Exiting."; return 0 ;;
            1) menu_run "Install" bash "${INSTALL_DIR}/installer/install.sh" ;;
            2) menu_run "Upgrade" "$0" upgrade ;;
            3) menu_run "Repair" "$0" repair ;;
            4) menu_run "Reinstall" bash "${INSTALL_DIR}/installer/install.sh" --reinstall ;;
            5) menu_run "Uninstall" "$0" uninstall ;;
            6) menu_run "Reset Administrator Username" "$0" admin reset-username ;;
            7) menu_run "Reset Administrator Password" "$0" admin reset-password ;;
            8) menu_run "Current Administrators" "$0" admin list ;;
            9) menu_run "Status" "$0" status ;;
            10) menu_run "Health" "$0" health ;;
            11) menu_run "Diagnostics" "$0" diagnostics run ;;
            12) menu_run "Logs" "$0" logs ;;
            13) menu_run "Start" "$0" start ;;
            14) menu_run "Stop" "$0" stop ;;
            15) menu_run "Restart" "$0" restart ;;
            16) menu_run "Backup" "$0" backup ;;
            17)
                read -r -p "Backup archive path: " archive
                menu_run "Restore" "$0" restore "$archive"
                ;;
            18) menu_run "Current Settings" "$0" configure show ;;
            19)
                read -r -p "New domain / public URL host: " new_domain
                menu_run "Edit Domain / Public URL" "$0" configure set app.domain "$new_domain"
                ;;
            20)
                read -r -p "New port: " new_port
                menu_run "Change Port" "$0" configure set app.port "$new_port"
                ;;
            21) echo "Install path: ${INSTALL_DIR}" ;;
            22) echo "Secret rotation is not automated in this release. Rotate values in .env.beta, then run: flowhub repair" ;;
            23) menu_run "Check Secret Exposure" "$0" configure verify ;;
            24) echo "Safety mode: Read-only. Apply, Scheduler, WooCommerce writes, and spreadsheet writes are disabled." ;;
            25) menu_run "Docker Compose Status" "$0" status ;;
            26) echo "Database: $(database_state)" ;;
            27) menu_run "Migration Status" "$0" migrate status ;;
            28) ensure_install; run_compose exec app bash ;;
            *) echo "Invalid selection: ${choice}" ;;
        esac
        echo ""
        read -r -p "Press Enter to return to the menu..." _ || return 0
    done
}

cmd="${1:-menu}"
case "$cmd" in
    menu)
        show_management_menu
        ;;
    ""|-h|--help|help)
        usage
        ;;
    install)
        shift
        ensure_install
        bash installer/install.sh "$@"
        ;;
    upgrade|update)
        shift
        ensure_install
        git pull origin main
        bash installer/install.sh --upgrade "$@"
        ;;
    repair)
        shift
        ensure_install
        bash installer/install.sh --repair "$@"
        ;;
    uninstall)
        shift
        ensure_install
        bash installer/install.sh --uninstall "$@"
        ;;
    status)
        shift
        ensure_install
        run_compose ps "$@"
        ;;
    health)
        shift
        ensure_install
        if command -v curl >/dev/null 2>&1; then
            curl -fsS "$(health_url)"
            echo
        else
            run_compose exec -T app curl -fsS http://localhost:8085/api/health
            echo
        fi
        ;;
    logs)
        shift
        ensure_install
        service="${1:-app}"
        run_compose logs -f "$service"
        ;;
    start)
        shift
        ensure_install
        run_compose up -d "$@"
        ;;
    restart)
        shift
        ensure_install
        run_compose restart "$@"
        wait_for_app_health 60
        ;;
    stop)
        shift
        ensure_install
        run_compose stop "$@"
        ;;
    backup)
        shift
        ensure_install
        mkdir -p backups
        stamp="$(date -u +%Y%m%dT%H%M%SZ)"
        archive="backups/flowhub-${stamp}.tar.gz"
        tar --exclude='logs/admin-credentials.txt' -czf "$archive" .env.beta storage logs 2>/dev/null \
            || tar -czf "$archive" .env.beta storage
        echo "Backup created: ${INSTALL_DIR}/${archive}"
        ;;
    restore)
        shift
        ensure_install
        archive="${1:-}"
        if [[ -z "$archive" || ! -f "$archive" ]]; then
            echo "ERROR: restore requires a backup archive path." >&2
            exit 1
        fi
        tar -xzf "$archive" -C "$INSTALL_DIR"
        echo "Backup restored. Run: flowhub repair"
        ;;
    *)
        ensure_install
        run_app_cli "$@"
        ;;
esac
