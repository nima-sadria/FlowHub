#!/usr/bin/env bash
# FlowHub management CLI wrapper.
#
# Installed to /usr/local/bin/flowhub by installer/install.sh.

set -euo pipefail

INSTALL_DIR="${FLOWHUB_INSTALL_DIR:-/opt/FlowHub}"
LEGACY_INSTALL_DIR="/opt/flowhub" # Legacy Compatibility
ENV_FILE="${INSTALL_DIR}/.env.beta"
COMPOSE_FILE="${INSTALL_DIR}/docker-compose.beta.yml"

usage() {
    cat <<'EOF'
FlowHub management commands:

  flowhub help             Show this help
  flowhub install          Run the installer
  flowhub upgrade          Pull latest code, rebuild, migrate, restart
  flowhub update           Alias for upgrade
  flowhub repair           Re-run migrations and health checks
  flowhub status           Show Docker service status
  flowhub health           Check the running application health endpoint
  flowhub logs [service]   Follow service logs
  flowhub start            Start the Docker stack
  flowhub restart          Restart services
  flowhub stop             Stop services
  flowhub uninstall        Run the uninstaller
  flowhub backup           Create a local backup archive
  flowhub restore FILE     Restore a local backup archive

App CLI commands are executed inside the app container, for example:
  flowhub diagnostics run
EOF
}

fail_missing_install() {
    echo "ERROR: FlowHub installation directory not found: ${INSTALL_DIR}" >&2
    if [[ -d "$LEGACY_INSTALL_DIR" ]]; then
        echo "Legacy Compatibility: installation detected at ${LEGACY_INSTALL_DIR}." >&2
        echo "Run the installer to migrate it to ${INSTALL_DIR}." >&2
    fi
    exit 1
}

ensure_install() {
    [[ -d "$INSTALL_DIR" ]] || fail_missing_install
    [[ -f "$COMPOSE_FILE" ]] || {
        echo "ERROR: Docker Compose file not found: ${COMPOSE_FILE}" >&2
        exit 1
    }
    [[ -f "$ENV_FILE" ]] || {
        echo "ERROR: Environment file not found: ${ENV_FILE}" >&2
        exit 1
    }
    cd "$INSTALL_DIR"
    set -a
    # shellcheck source=/dev/null
    . "$ENV_FILE"
    set +a
}

compose_cmd() {
    if docker compose version >/dev/null 2>&1; then
        echo "docker compose"
    elif command -v docker-compose >/dev/null 2>&1; then
        echo "docker-compose"
    else
        echo "ERROR: Docker Compose is not available." >&2
        exit 1
    fi
}

run_compose() {
    local dc
    dc="$(compose_cmd)"
    ${dc} --project-directory "$INSTALL_DIR" -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

run_app_cli() {
    run_compose exec -T app python -m cli.main "$@"
}

health_url() {
    echo "http://localhost:${BETA_PORT:-8085}/api/health"
}

check_app_health() {
    if command -v curl >/dev/null 2>&1; then
        curl -fsS --max-time 3 "$(health_url)" >/dev/null 2>&1
    else
        run_compose exec -T app curl -fsS --max-time 3 http://localhost:8085/api/health >/dev/null 2>&1
    fi
}

wait_for_app_health() {
    local timeout="${1:-60}"
    local start now
    start="$(date +%s)"
    echo "Waiting for FlowHub to become ready at $(health_url) ..."
    while true; do
        if check_app_health; then
            echo "FlowHub is ready."
            return 0
        fi
        now="$(date +%s)"
        if (( now - start >= timeout )); then
            echo "WARNING: FlowHub did not become ready within ${timeout}s." >&2
            echo "Services may still be starting. Check with: flowhub health" >&2
            return 1
        fi
        sleep 2
    done
}

cmd="${1:-help}"
case "$cmd" in
    ""|-h|--help|help)
        usage
        ;;
    install)
        shift
        ensure_install
        bash installer/install.sh "$@"
        ;;
    upgrade|update)
        shift
        ensure_install
        git pull origin main
        bash installer/install.sh --upgrade "$@"
        ;;
    repair)
        shift
        ensure_install
        bash installer/install.sh --repair "$@"
        ;;
    uninstall)
        shift
        ensure_install
        bash installer/install.sh --uninstall "$@"
        ;;
    status)
        shift
        ensure_install
        run_compose ps "$@"
        ;;
    health)
        shift
        ensure_install
        if command -v curl >/dev/null 2>&1; then
            curl -fsS "$(health_url)"
            echo
        else
            run_compose exec -T app curl -fsS http://localhost:8085/api/health
            echo
        fi
        ;;
    logs)
        shift
        ensure_install
        service="${1:-app}"
        run_compose logs -f "$service"
        ;;
    start)
        shift
        ensure_install
        run_compose up -d "$@"
        ;;
    restart)
        shift
        ensure_install
        run_compose restart "$@"
        wait_for_app_health 60
        ;;
    stop)
        shift
        ensure_install
        run_compose stop "$@"
        ;;
    backup)
        shift
        ensure_install
        mkdir -p backups
        stamp="$(date -u +%Y%m%dT%H%M%SZ)"
        archive="backups/flowhub-${stamp}.tar.gz"
        tar --exclude='logs/admin-credentials.txt' -czf "$archive" .env.beta storage logs 2>/dev/null \
            || tar -czf "$archive" .env.beta storage
        echo "Backup created: ${INSTALL_DIR}/${archive}"
        ;;
    restore)
        shift
        ensure_install
        archive="${1:-}"
        if [[ -z "$archive" || ! -f "$archive" ]]; then
            echo "ERROR: restore requires a backup archive path." >&2
            exit 1
        fi
        tar -xzf "$archive" -C "$INSTALL_DIR"
        echo "Backup restored. Run: flowhub repair"
        ;;
    *)
        ensure_install
        run_app_cli "$@"
        ;;
esac
