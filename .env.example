# FlowHub - Environment template
# Copy to .env and fill in real values before deploying.
# .env is gitignored. Never commit the file with real secrets.
#
# Generate secrets:
#   python3 -c "import secrets; print(secrets.token_hex(48))"  # 96-char hex

# -- Profile -------------------------------------------------------------------
FLOWHUB_ENV=production
FLOWHUB_DOMAIN=your-flowhub-domain.example.com
FLOWHUB_PORT=8085
FLOWHUB_SSL_MODE=manual

# -- Database ------------------------------------------------------------------
FLOWHUB_DATABASE_URL=postgresql://flowhub:CHANGE_ME_DB_PASSWORD@postgres:5432/flowhub
FLOWHUB_POSTGRES_DB=flowhub
FLOWHUB_POSTGRES_USER=flowhub
FLOWHUB_POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# -- JWT and API secrets -------------------------------------------------------
# Must be at least 64 characters for JWT_SECRET, 32 for REST_API_SECRET
FLOWHUB_JWT_SECRET=CHANGE_ME_64_CHAR_MIN_eg_run_python_secrets_token_hex_48_here_xxxx
FLOWHUB_REST_API_SECRET=CHANGE_ME_32_CHAR_MIN_eg_run_python_secrets_here
# Leave empty unless FlowHub is deployed behind a trusted reverse proxy.
# Comma-separated IPs/CIDRs are allowed, for example: 172.18.0.0/16
FLOWHUB_TRUSTED_PROXY_NETWORKS=

# -- Nextcloud source ----------------------------------------------------------
FLOWHUB_NEXTCLOUD_URL=https://your-nextcloud.example.com
FLOWHUB_NEXTCLOUD_FILE_PATH=/remote.php/dav/files/username/folder/price-list.xlsx
FLOWHUB_NEXTCLOUD_USERNAME=your_nextcloud_user
FLOWHUB_NEXTCLOUD_PASSWORD=CHANGE_ME_NEXTCLOUD_PASSWORD

# -- WooCommerce channel -------------------------------------------------------
FLOWHUB_WOOCOMMERCE_URL=https://your-woocommerce.example.com
FLOWHUB_WOOCOMMERCE_KEY=ck_CHANGE_ME_WOOCOMMERCE_KEY
FLOWHUB_WOOCOMMERCE_SECRET=cs_CHANGE_ME_WOOCOMMERCE_SECRET

# -- Locale --------------------------------------------------------------------
FLOWHUB_TIMEZONE=Asia/Tehran
FLOWHUB_CURRENCY=IRR

# -- Admin ---------------------------------------------------------------------
FLOWHUB_ADMIN_EMAIL=admin@example.com

# -- Storage paths (resolved inside the container) -----------------------------
FLOWHUB_STORAGE_PATH=/data/storage
FLOWHUB_BACKUP_PATH=/data/backups

# -- Optional - defaults shown -------------------------------------------------
FLOWHUB_LOG_LEVEL=INFO
FLOWHUB_MAX_UPLOAD_MB=50
FLOWHUB_WORKER_CONCURRENCY=2
FLOWHUB_ORDER_SYNC_ENABLED=true
FLOWHUB_ORDER_SYNC_RUNNER_POLL_SECONDS=30
FLOWHUB_ORDER_SYNC_POLL_INTERVAL_SECONDS=300
FLOWHUB_ORDER_SYNC_RECONCILE_INTERVAL_SECONDS=900
FLOWHUB_ORDER_SYNC_LEASE_SECONDS=900
FLOWHUB_ORDER_SYNC_MAX_PAGES=10
FLOWHUB_ORDER_SYNC_RECONCILE_PAGE_SIZE=50
FLOWHUB_ORDER_SYNC_WEBHOOK_BATCH_SIZE=100
FLOWHUB_ORDER_SYNC_OPERATION_TIMEOUT_SECONDS=60
FLOWHUB_SNAPPSHOP_PRODUCT_SYNC_MAX_PAGES=250
FLOWHUB_SNAPPSHOP_PRODUCT_SYNC_RETRIES=2
FLOWHUB_SNAPPSHOP_PRODUCT_SYNC_PAGE_DELAY_SECONDS=1.1
FLOWHUB_SNAPPSHOP_PRODUCT_SYNC_RATE_LIMIT_BACKOFF_SECONDS=30
FLOWHUB_BACKUP_RETAIN_DAYS=30
FLOWHUB_JWT_ACCESS_TTL_MINUTES=15
FLOWHUB_JWT_REFRESH_TTL_DAYS=7
