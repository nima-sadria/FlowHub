# Legacy Compatibility
#
# The first-release Docker installer uses .env.beta.example and generates
# /opt/FlowHub/.env.beta automatically. This file remains only for old local
# root-app workflows and is not required for normal installation.

# -- App -----------------------------------------------------------------------
# SQLite fallback for legacy local development only.
DATABASE_URL=sqlite:///./flowhub-legacy.db

# -- Security -----------------------------------------------------------------
# JWT secret - REQUIRED in production. Must be at least 32 bytes (64+ recommended).
# Generate with: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET=change-me-in-production

# Set to true in production to hide /docs and /openapi.json from the public.
# Keep false (or omit) in development environments.
DISABLE_DOCS=false

# -- Access Control (Phase 0) -------------------------------------------------
# Super admins bypass the app_users DB table entirely.
# These users can ALWAYS log in even if app_users is empty.
# Comma-separated Nextcloud usernames.
SUPER_ADMIN_USERS=admin

# Bootstrap seed: users created in app_users on first startup if not already present.
# Supports 'username' or 'username:email' format (comma-separated).
# Email is stored in app_users.email and enables login via email address.
# Never overwrites existing rows. Backfills email if previously unset. Safe to leave set permanently.
BOOTSTRAP_APP_ADMINS=admin:admin@example.com
BOOTSTRAP_APP_USERS=

# -- Cache / Sync -------------------------------------------------------------
# Product cache TTL in hours (0 = disable caching). Connectors are configured
# after setup from Settings -> Integrations.
WC_CACHE_TTL_HOURS=6
# Automatic product fetching is disabled by default for first release safety.
WC_AUTO_FETCH_HOURS=0

# -- Currency proxy ------------------------------------------------------------
# alanchand.com API token for IRR exchange rates (USD/EUR/AED/TRY).
# Required for the /api/currency endpoint to return live data.
ALANCHAND_API_TOKEN=your_alanchand_token_here
