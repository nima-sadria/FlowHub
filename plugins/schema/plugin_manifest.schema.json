{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "flowhub-plugin-manifest",
  "title": "FlowHub Plugin Manifest",
  "description": "JSON Schema for FlowHub plugin.json manifests. Implementation begins after first release.",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "category",
    "author",
    "description",
    "min_flowhub_version",
    "entry_point",
    "class_name",
    "permissions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique kebab-case plugin identifier"
    },
    "name": {
      "type": "string",
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SemVer version string"
    },
    "category": {
      "type": "string",
      "enum": [
        "source_adapter",
        "channel_adapter",
        "rule_extension",
        "safety_policy",
        "ui_module",
        "report_module"
      ]
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string",
      "maxLength": 200
    },
    "min_flowhub_version": {
      "type": "string"
    },
    "max_flowhub_version": {
      "type": ["string", "null"],
      "default": null
    },
    "entry_point": {
      "type": "string",
      "description": "Python file relative to plugin root"
    },
    "class_name": {
      "type": "string",
      "description": "Class to instantiate from entry_point"
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Permissions this plugin requires"
    },
    "config_schema": {
      "type": ["object", "null"],
      "default": null,
      "description": "JSON Schema for plugin-specific config values"
    },
    "tep_position": {
      "type": ["string", "null"],
      "enum": ["rule_engine", "safety_engine", null],
      "default": null
    },
    "ui_routes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["path", "component"],
        "properties": {
          "path": { "type": "string" },
          "component": { "type": "string" },
          "nav_label": { "type": "string" },
          "nav_icon": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
